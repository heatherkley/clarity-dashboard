# Clarity Dashboard — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local development (it is git-ignored).
# For GitHub Actions, add each of these as a Repository Secret:
#   GitHub repo → Settings → Secrets and variables → Actions → New repository secret
#
# ─────────────────────────────────────────────────────────────────────────────

# CONFIG_JSON
# The full contents of your config.json file, pasted as a single secret.
# This includes all Clarity tokens, RevenueCat keys, and ASC app IDs.
# Tip: copy your config.json content and paste it into this GitHub Secret.
CONFIG_JSON={"projects":[...],"appstore_connect":{...},"revenuecat":{...}}

# ── App Store Connect Private Keys ────────────────────────────────────────────
# The full contents of each .p8 key file (the private key Apple gives you).
# Include the -----BEGIN PRIVATE KEY----- and -----END PRIVATE KEY----- lines.

# Shift Apple Developer account key
ASC_KEY_SHIFT=-----BEGIN PRIVATE KEY-----
...your shift.p8 contents here...
-----END PRIVATE KEY-----

# Today's Front Pages Apple Developer account key
ASC_KEY_TODAYS_FRONT_PAGES=-----BEGIN PRIVATE KEY-----
...your frontPages.p8 contents here...
-----END PRIVATE KEY-----

# P3 Apple Developer account key
ASC_KEY_P3=-----BEGIN PRIVATE KEY-----
...your p3.p8 contents here...
-----END PRIVATE KEY-----
